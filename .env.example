# LLM
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Agent
AGENT_MAX_TOOL_ROUNDS=4

# Database
# Docker Compose (API in container): use service names below
# Local uvicorn on host: use localhost — postgres/redis/chroma must be running (docker compose up -d postgres redis chroma)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/legal_assistant
REDIS_URL=redis://localhost:6379/0

# Chroma
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Embedding
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# RAG (coarse retrieve + rerank)
RAG_COARSE_TOP_K=20
RAG_FINAL_TOP_K=5
RAG_RERANK_MODEL=BAAI/bge-reranker-base
RAG_WARMUP_ON_STARTUP=false

# Weather
WEATHER_PROVIDER=open_meteo
QWEATHER_API_KEY=
GAODE_API_KEY=

# Memory
MAX_HISTORY_TURNS=20
REDIS_SESSION_TTL_SECONDS=86400

# Observability (Langfuse v3 server + Python SDK v4)
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Security (optional)
API_KEY=

# Startup
SKIP_AUTO_INGEST=false
